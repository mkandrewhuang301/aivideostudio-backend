PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
REDIS_URL=redis://localhost:6379
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=aivideostudio
R2_PUBLIC_DOMAIN=
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=com.fantasiaai.app

# Phase 18 — Apple DeviceCheck free-credit anti-abuse
DEVICE_CHECK_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
DEVICE_CHECK_KEY_ID=your-devicecheck-key-id
DEVICE_CHECK_TEAM_ID=your-apple-team-id
FREE_CREDIT_BUNDLE=5

REPLICATE_API_TOKEN=your-replicate-api-token
REPLICATE_WEBHOOK_SECRET=your-replicate-webhook-secret
PUBLIC_BASE_URL=https://your-backend-domain.com
# Phase 5 — Content Moderation
HIVE_API_KEY=your-hive-moderation-api-key
# Separate key issued/mapped after Hive enables Combined CSAM Detection (Thorn).
HIVE_CSAM_API_KEY=
HIVE_INPUT_SCAN_ENABLED=true
HIVE_INPUT_NSFW_THRESHOLD=0.85
# Policy v2: ONLY generations persisted with has_real_face_input=true are output-scanned.
HIVE_SCAN_REAL_FACE_PATHS=false
HIVE_LOW_CHILD_THRESHOLD=0.80
HIVE_LOW_SEXUAL_THRESHOLD=0.70
OPENAI_API_KEY=your-openai-api-key

# Video Summarizer + native Google narration/music. Set either switch false for an immediate
# rollback; Fal remains the configured automatic fallback while Google audio models are preview.
GEMINI_API_KEY=your-gemini-api-key
VIDEO_SUMMARY_MODEL=gemini-3.5-flash
VIDEO_SUMMARY_TEXT_MODEL=gemini-3.5-flash-lite
VIDEO_SUMMARY_WIKIPEDIA_ENABLED=true
GOOGLE_NATIVE_AUDIO_ENABLED=true
GOOGLE_AUDIO_FAL_FALLBACK_ENABLED=true
FAL_TTS_FALLBACK_MODEL=fal-ai/gemini-3.1-flash-tts
FAL_LYRIA_FALLBACK_MODEL=fal-ai/lyria2

# Edit Studio AI Music. Keep disabled until the app-wide 18+ eligibility gate is approved.
AI_MUSIC_ENABLED=false
AI_MUSIC_PROVIDER=lyria
LYRIA_CLIP_MODEL=lyria-3-clip-preview
LYRIA_PRO_MODEL=lyria-3-pro-preview
AI_MUSIC_MAX_DURATION_SECONDS=184
AI_MUSIC_WORKER_CONCURRENCY=2
AI_MUSIC_REQUESTS_PER_MINUTE=8
AI_MUSIC_ANALYSIS_MODEL=gemini-3.1-flash-lite
AI_MUSIC_ANALYSIS_FRAME_COUNT=5

# NCMEC CyberTipline Reporting API (issued after ESP registration)
NCMEC_ESP_USERNAME=
NCMEC_ESP_PASSWORD=
NCMEC_REPORTER_EMAIL=
# Use https://exttest.cybertip.org/ispws until NCMEC approves production reporting.
NCMEC_API_BASE_URL=https://report.cybertip.org/ispws
ABUSE_CONTACT_EMAIL=
