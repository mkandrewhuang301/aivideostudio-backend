{
  "name": "aivideostudio-backend",
  "version": "1.0.0",
  "description": "Fantasia AI Video Studio — Node.js/TypeScript backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "smoke:queue": "tsx src/queue/testWorker.ts",
    "smoke:r2": "tsx src/storage/smokeTest.ts",
    "upload:preset-art": "tsx src/scripts/uploadPresetArt.ts",
    "upload:preset-music": "tsx src/scripts/uploadPresetMusic.ts",
    "eslint": "eslint src --ext .ts",
    "test": "jest --passWithNoTests"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1080.0",
    "@aws-sdk/client-s3": "^3.817.0",
    "@aws-sdk/lib-storage": "^3.1078.0",
    "@aws-sdk/s3-request-presigner": "^3.817.0",
    "@neondatabase/serverless": "^1.0.0",
    "@parse/node-apn": "^8.1.0",
    "@types/express": "^5.0.3",
    "bullmq": "^5.56.7",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.1",
    "express": "^4.21.2",
    "firebase-admin": "^13.4.0",
    "ioredis": "^5.6.1",
    "multer": "^2.2.0",
    "replicate": "^1.4.0",
    "sharp": "^0.33.5",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  }
}
